# Server binding — use 127.0.0.1, not localhost (avoids IPv6 binding on some systems)
HOST=127.0.0.1
PORT=4393

# Public site origin.
# Read by astro.config.mjs at build time — sets canonical URLs and sitemap.
# Dev: set to http://localhost:4321 (sitemaps/canonicals point to localhost, fine for dev)
# Production: set to https://link.nickcardoso.com
ORIGIN=https://link.nickcardoso.com

# Node environment
NODE_ENV=production
