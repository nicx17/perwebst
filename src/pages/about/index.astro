---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBack from "../../components/NavBack.astro";
import { pipeline, optimizationNotes, stackCards } from "../../data/about";
---

<BaseLayout
  title="About This Site | Nick Cardoso"
  description="Technical architecture and deployment details for Nick Cardoso's portfolio site."
  canonicalPath="/about/"
  shell={false}
>
  <NavBack href="/" label="<- Home" />

  <header class="page-header">
    <h1>System Architecture</h1>
    <p class="subtitle">How this site is built, deployed, and secured.</p>
  </header>

  <section data-reveal>
    <h2>The Stack</h2>
    <div class="project-grid" data-reveal-stagger>
      {stackCards.map((item) => (
        <article class="section-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section data-reveal>
    <h2>Deployment Pipeline</h2>
    <table class="data-table" data-reveal-stagger>
      <caption>CI/CD stages from commit to production.</caption>
      <tbody>
        {pipeline.map(([key, value]) => (
          <tr>
            <th scope="row">{key}</th>
            <td>{value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section data-reveal>
    <h2>Performance and Optimizations</h2>
    <table class="data-table" data-reveal-stagger>
      <caption>Architectural decisions and their rationale.</caption>
      <tbody>
        {optimizationNotes.map(([key, value]) => (
          <tr>
            <th scope="row">{key}</th>
            <td>{value}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
