---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBack from '../../components/NavBack.astro';
import ProjectHero from '../../components/project/ProjectHero.astro';

const slug = Astro.params.slug ?? '';
const expectedPath = `/projects/${slug}/`;
const projects = await getCollection('projects');
const project = projects.find(
  (entry) => entry.data.canonicalPath === expectedPath
);

let Content;
if (project) {
  const rendered = await render(project);
  Content = rendered.Content;
} else {
  Astro.response.status = 404;
}
---

{
  project && Content ? (
    <BaseLayout
      title={`${project.data.title} | Nick Cardoso`}
      description={project.data.summary}
      canonicalPath={project.data.canonicalPath}
      shell={false}
    >
      <NavBack href="/projects/" label="<- Back to Projects" />

      <article class="article project-detail-card">
        <ProjectHero
          title={project.data.title}
          summary={project.data.summary}
          icon={project.data.icon}
          repository={project.data.repository}
          liveUrl={project.data.liveUrl}
          tags={project.data.tags}
        />

        <section class="article-content project-detail-content">
          <Content />
        </section>
      </article>
    </BaseLayout>
  ) : (
    <BaseLayout
      title="Project Not Found | Nick Cardoso"
      description="The requested project page does not exist."
      canonicalPath={expectedPath}
      shell={false}
    >
      <NavBack href="/projects/" label="<- Back to Projects" />
      <article class="article project-detail-card">
        <header>
          <h1>Project Not Found</h1>
          <p class="subtitle projects-page-subtitle">
            The URL you requested does not match an available project.
          </p>
        </header>
      </article>
    </BaseLayout>
  )
}

<script>
  function setupCopyButtons() {
    const codeBlocks = document.querySelectorAll('.project-detail-content pre');

    codeBlocks.forEach((block) => {
      if (block.parentElement?.classList.contains('code-wrapper')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'code-wrapper';
      block.parentNode?.insertBefore(wrapper, block);
      wrapper.appendChild(block);

      const copyButton = document.createElement('button');
      copyButton.className = 'copy-code-btn';
      copyButton.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      `;
      copyButton.setAttribute('aria-label', 'Copy code');
      copyButton.setAttribute('title', 'Copy code');

      wrapper.appendChild(copyButton);

      copyButton.addEventListener('click', async () => {
        const code = block.querySelector('code');
        const text = code ? code.innerText : block.innerText;

        try {
          await navigator.clipboard.writeText(text);
          copyButton.classList.add('copied');
          copyButton.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          `;
          setTimeout(() => {
            copyButton.classList.remove('copied');
            copyButton.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
            `;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      });
    });
  }

  // Run setup when the page finishes parsing
  document.addEventListener('DOMContentLoaded', setupCopyButtons);
  // Fallback for Astro page load events if View Transitions are used
  document.addEventListener('astro:page-load', setupCopyButtons);

  // Safety execution for instant loading
  if (
    document.readyState === 'interactive' ||
    document.readyState === 'complete'
  ) {
    setupCopyButtons();
  }
</script>
