---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBack from "../../components/NavBack.astro";

const slug = Astro.params.slug ?? "";
const expectedPath = `/projects/${slug}/`;
const projects = await getCollection("projects");
const project = projects.find((entry) => entry.data.canonicalPath === expectedPath);

let Content;
if (project) {
  const rendered = await render(project);
  Content = rendered.Content;
} else {
  Astro.response.status = 404;
}

const repositoryHost = project ? new URL(project.data.repository).hostname.replace(/^www\./, "") : "";
const liveHost = project?.data.liveUrl
  ? new URL(project.data.liveUrl).hostname.replace(/^www\./, "")
  : "";
---

{
  project && Content ? (
    <BaseLayout
      title={`${project.data.title} | Nick Cardoso`}
      description={project.data.summary}
      canonicalPath={project.data.canonicalPath}
      shell={false}
    >
      <NavBack href="/projects/" label="<- Back to Projects" />

      <article class="article project-detail-card">
        <header class="project-detail-header">
          <div class="project-detail-title-wrap">
            <div class="project-detail-icon-box" aria-hidden="true">
              {
                project.data.icon ? (
                  <img
                    class="project-detail-icon"
                    src={project.data.icon}
                    alt=""
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <span class="project-detail-icon-fallback">{project.data.title.slice(0, 1)}</span>
                )
              }
            </div>
            <div>
              <h1>{project.data.title}</h1>
              <p class="subtitle projects-page-subtitle">{project.data.summary}</p>
            </div>
          </div>
          <div class="meta-row">
            <div class="project-action-row" aria-label="Project actions">
              <a
                class="project-action-button project-action-primary"
                href={project.data.repository}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Open source repository on ${repositoryHost}`}
              >
                View Source
              </a>
              {
                project.data.liveUrl ? (
                  <a
                    class="project-action-button"
                    href={project.data.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Open live site at ${liveHost}`}
                  >
                    Visit Live Site
                  </a>
                ) : null
              }
            </div>
            <div class="project-meta-row" aria-label="Project hosts">
              <span class="project-meta-chip">{repositoryHost}</span>
              {liveHost ? <span class="project-meta-chip">{liveHost}</span> : null}
            </div>
          </div>
          <div class="tag-list">
            {project.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </header>

        <section class="article-content project-detail-content">
          <Content />
        </section>
      </article>
    </BaseLayout>
  ) : (
    <BaseLayout
      title="Project Not Found | Nick Cardoso"
      description="The requested project page does not exist."
      canonicalPath={expectedPath}
      shell={false}
    >
      <NavBack href="/projects/" label="<- Back to Projects" />
      <article class="article project-detail-card">
        <header>
          <h1>Project Not Found</h1>
          <p class="subtitle projects-page-subtitle">The URL you requested does not match an available project.</p>
        </header>
      </article>
    </BaseLayout>
  )
}
