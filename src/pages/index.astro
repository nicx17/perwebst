---
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeLinks } from "../data/links";

const homeLinkIcons: Record<string, { viewBox: string; path: string; key: string }> = {
  Projects: {
    viewBox: "0 0 24 24",
    path: "M3 6a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Z",
    key: "projects"
  },
  GitHub: {
    viewBox: "-1 -1 18 18",
    path: "M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.65 7.65 0 0 1 8 4.68c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z",
    key: "github"
  },
  LinkedIn: {
    viewBox: "0 0 24 24",
    path: "M5.1 8.6A1.8 1.8 0 1 1 5.1 5a1.8 1.8 0 0 1 0 3.6ZM3.5 10h3.2v10.5H3.5V10Zm5.2 0h3v1.5h.1c.4-.8 1.4-1.7 3-1.7 3.2 0 3.8 2.1 3.8 4.9v5.8h-3.2v-5.2c0-1.2 0-2.9-1.8-2.9s-2.1 1.4-2.1 2.8v5.3H8.7V10Z",
    key: "linkedin"
  },
  Unsplash: {
    viewBox: "0 0 24 24",
    path: "M9 4h6v8H9V4Zm-6 10h18v6H3v-6Z",
    key: "unsplash"
  },
  Instagram: {
    viewBox: "0 0 24 24",
    path: "M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 2A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9Zm10.75 1.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z",
    key: "instagram"
  }
};
---

<BaseLayout
  title="Nick Cardoso - Links"
  description="Nick Cardoso's technical portfolio, infrastructure documentation, and project links."
  canonicalPath="/"
  shell={false}
>
  <section class="home-stage">
    <header class="page-header home-hero">
      <h1>Nick Cardoso</h1>
      <p class="subtitle">Engineering and Photography</p>
    </header>

    <section class="home-links home-links-centered" aria-label="Primary links">
      {homeLinks.map((link) => {
        const icon = homeLinkIcons[link.label] ?? homeLinkIcons.Projects;

        return (
          <a
            class="home-link"
            data-icon={icon.key}
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
          >
            <span class="home-link-icon" aria-hidden="true">
              <svg viewBox={icon.viewBox} focusable="false">
                <path d={icon.path}></path>
              </svg>
            </span>
            <span class="home-link-label">{link.label}</span>
          </a>
        );
      })}
    </section>
  </section>
</BaseLayout>
