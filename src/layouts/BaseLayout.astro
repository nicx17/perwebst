---
import "../styles/global.css";
import { ClientRouter } from 'astro:transitions';
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  shell?: boolean;
  theme?: "ivory" | "midnight";
}

const { title, description, canonicalPath, shell = true, theme } = Astro.props;
const canonical = canonicalPath ? new URL(canonicalPath, Astro.site).toString() : undefined;
const pathname = Astro.url.pathname;
const pageUrl = new URL(pathname, Astro.site).toString();

const day = new Date().getDate();
const isDay2 = day % 2 === 0;

const lightImage = isDay2 ? "eve-lP_4h4oVO1E-unsplash" : "eve-jCBLFtjpXfw-unsplash";
const darkImage = isDay2 ? "mohammed-kara-LpYWTqT4Ff0-unsplash" : "jan-kopriva-L-bVMhRb5cs-unsplash";

const ogImage = new URL(`/backgrounds/light/${lightImage}.jpg`, Astro.site).toString();
const cspNonce = typeof Astro.locals.cspNonce === "string" ? Astro.locals.cspNonce : undefined;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/about/", label: "About" }
];

const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname.startsWith(href);
};
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    <script is:inline nonce={cspNonce} data-cfasync="false">
      if (globalThis.trustedTypes && globalThis.trustedTypes.createPolicy) {
        try {
          if (!globalThis.trustedTypes.defaultPolicy) {
            globalThis.trustedTypes.createPolicy("default", {
              createHTML: (string) => string,
              createScript: (string) => string,
              createScriptURL: (string) => string
            });
          }
        } catch {}
      }
    </script>
    <script is:inline nonce={cspNonce} data-cfasync="false">
      (() => {
        try {
          const root = document.documentElement;
          const savedTheme = localStorage.getItem("theme");
          if (savedTheme === "ivory" || savedTheme === "midnight") {
            root.dataset.theme = savedTheme;
          }

          const activeTheme = root.dataset.theme === "ivory" || root.dataset.theme === "midnight" ? root.dataset.theme : "ivory";
          const sceneQualityKey = (theme) => `bg-scene-quality-20260404hq-${theme}`;
          const cachedSceneQuality = sessionStorage.getItem(sceneQualityKey(activeTheme));
          if (cachedSceneQuality === "tiny" || cachedSceneQuality === "avif" || cachedSceneQuality === "webp" || cachedSceneQuality === "default") {
            root.dataset.sceneQuality = cachedSceneQuality;
          }
        } catch {
          /* Ignore storage access failures in restricted browser modes. */
        }
      })();
    </script>
    <script is:inline src="/js/page-transition.js" nonce={cspNonce} defer data-cfasync="false"></script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content={theme === "midnight" ? "#02060d" : "#ece9e3"} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical ?? pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    {canonical && <link rel="canonical" href={canonical} />}
    <script is:inline src="/js/theme-toggle.js" nonce={cspNonce} defer data-cfasync="false"></script>
    <style is:inline nonce={cspNonce} set:html={`
      :root {
        --scene-image-default-light: url("/backgrounds/light/${lightImage}.jpg?v=20260404hq");
        --scene-image-tiny-light: url("/backgrounds/light/${lightImage}.tiny.webp?v=20260404hq");
        --scene-image-webp-light: url("/backgrounds/light/${lightImage}.webp?v=20260404hq");
        --scene-image-avif-light: url("/backgrounds/light/${lightImage}.avif?v=20260404hq");

        --scene-image-default-dark: url("/backgrounds/dark/${darkImage}.jpg?v=20260404hq");
        --scene-image-tiny-dark: url("/backgrounds/dark/${darkImage}.tiny.webp?v=20260404hq");
        --scene-image-webp-dark: url("/backgrounds/dark/${darkImage}.webp?v=20260404hq");
        --scene-image-avif-dark: url("/backgrounds/dark/${darkImage}.avif?v=20260404hq");
      }

      html[data-theme="ivory"], html:not([data-theme]) {
        --scene-image-default: var(--scene-image-default-light);
        --scene-image-tiny: var(--scene-image-tiny-light);
        --scene-image-webp: var(--scene-image-webp-light);
        --scene-image-avif: var(--scene-image-avif-light);
        --scene-image: var(--scene-image-default);
      }
      html[data-theme="midnight"] {
        --scene-image-default: var(--scene-image-default-dark);
        --scene-image-tiny: var(--scene-image-tiny-dark);
        --scene-image-webp: var(--scene-image-webp-dark);
        --scene-image-avif: var(--scene-image-avif-dark);
        --scene-image: var(--scene-image-default);
      }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme]) {
          --scene-image-default: var(--scene-image-default-dark);
          --scene-image-tiny: var(--scene-image-tiny-dark);
          --scene-image-webp: var(--scene-image-webp-dark);
          --scene-image-avif: var(--scene-image-avif-dark);
          --scene-image: var(--scene-image-default);
        }
      }

      html[data-scene-quality="tiny"] { --scene-image: var(--scene-image-tiny, var(--scene-image-default)); }
      html[data-scene-quality="webp"] { --scene-image: var(--scene-image-webp, var(--scene-image-default)); }
      html[data-scene-quality="avif"] { --scene-image: var(--scene-image-avif, var(--scene-image-default)); }
      html[data-scene-quality="default"] { --scene-image: var(--scene-image-default); }
    `}></style>
    <script is:inline nonce={cspNonce} set:html={`
      globalThis.__BACKGROUND_CONFIG = {
        ivory: "/backgrounds/light/${lightImage}.jpg",
        midnight: "/backgrounds/dark/${darkImage}.jpg"
      };
    `}></script>
    <script is:inline src="/js/background-loader.js" nonce={cspNonce} defer data-cfasync="false"></script>
  </head>
  <body>
    <div id="scene-bg" aria-hidden="true"></div>
    <div class="ambient-orb ambient-orb-one" aria-hidden="true"></div>
    <div class="ambient-orb ambient-orb-two" aria-hidden="true"></div>
    <main class:list={{ "page-shell": true, "page-shell-plain": !shell }}>
      {
        shell ? (
          <section class="app-shell">
            <header class="app-topbar">
              <div class="app-controls">
                <nav class="app-nav" aria-label="Primary">
                  {navItems.map((item) => (
                    <a
                      class:list={{ "app-tab": true, "is-active": isActive(item.href) }}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  ))}
                </nav>
                <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
                  <span class="theme-toggle-label theme-toggle-label-ivory">Ivory</span>
                  <span class="theme-toggle-label theme-toggle-label-midnight">Midnight</span>
                  <span class="theme-toggle-thumb" aria-hidden="true"></span>
                </button>
              </div>
            </header>

            <section class="app-content">
              <slot />
            </section>
          </section>
        ) : (
          <>
            <header class="app-topbar app-topbar-plain">
              <div class="app-controls">
                <nav class="app-nav" aria-label="Primary">
                  {navItems.map((item) => (
                    <a
                      class:list={{ "app-tab": true, "is-active": isActive(item.href) }}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  ))}
                </nav>
                <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
                  <span class="theme-toggle-label theme-toggle-label-ivory">Ivory</span>
                  <span class="theme-toggle-label theme-toggle-label-midnight">Midnight</span>
                  <span class="theme-toggle-thumb" aria-hidden="true"></span>
                </button>
              </div>
            </header>

            <section class="app-content app-content-plain">
              <slot />
            </section>
          </>
        )
      }
    </main>
  </body>
</html>
