---
/**
 * BaseLayout is the primary shell for all pages in the application.
 * It handles the global HTML structure, theme management, background image rotation,
 * and security header passthrough (nonces).
 */
import "../styles/global.css";
import { ClientRouter } from 'astro:transitions';
import { getTopbarPersistKey } from "../utils/layout-shell";
interface Props {
  /** The page title used in the <title> tag and OG/Twitter metadata. */
  title: string;
  /** A concise summary of the page for SEO and social sharing. */
  description?: string;
  /** The absolute URL for the canonical link relation, if different from the current URL. */
  canonicalPath?: string;
  /** Controls whether the standard app shell (topbar, navigation) is rendered. */
  shell?: boolean;
  /** Explicitly overrides the theme (useful for landing pages or specific modes). */
  theme?: "ivory" | "midnight";
}

const { title, description, canonicalPath, shell = true, theme } = Astro.props;
const canonical = canonicalPath ? new URL(canonicalPath, Astro.site).toString() : undefined;
const pathname = Astro.url.pathname;
const pageUrl = new URL(pathname, Astro.site).toString();
const topbarPersistKey = getTopbarPersistKey(shell);

/**
 * Background selective logic based on the current day of the month.
 * This ensures a variety of imagery across the month while remaining deterministic
 * for SSR/Hydration consistency.
 */
const day = new Date().getDate();

/** Pools of background images for light (ivory) and dark (midnight) themes. */
const lightImages: string[] = [
  "antonius-harel-2rkqE7SgcE8-unsplash",
  "antonius-harel-VbOjY42c6a4-unsplash",
  "antonius-harel-WsaPcg512jE-unsplash",
  "asi-mong-Gf5Q_5UF3vs-unsplash",
  "asif-aether-TlHglbjfvqw-unsplash",
  "dirk-lach--IZ8j4_xgQ8-unsplash",
  "dirk-lach-_uamwvb8UlI-unsplash",
  "eve-9xY__xnwCy0-unsplash",
  "eve-Fp96C-6Wd6o-unsplash",
  "eve-WK9sTh1FiSs-unsplash",
  "eve-bKOpGRbHBGs-unsplash",
  "eve-jCBLFtjpXfw-unsplash",
  "eve-lP_4h4oVO1E-unsplash",
  "eve-lxepp3ZUxTs-unsplash",
  "hassaan-here-bKfkhVRAJTQ-unsplash",
  "iklas-FeNrGgQ1Tu8-unsplash",
  "iklas-OSoICiA8F4M-unsplash",
  "iklas-xjSu2KbJlAg-unsplash",
  "iklas-y9Ujplj3KIU-unsplash",
  "mohammad-alizade-nIlwOYUbQEA-unsplash",
  "mymind-KnUX9qtR_4E-unsplash",
  "omid-armin-Nsn9FY4JGMs-unsplash",
  "plufow-le-studio-aE8Mx8-vQss-unsplash",
  "radoslav-bali-Bp2sWPJGPHs-unsplash",
  "radoslav-bali-rhnZzt9XblE-unsplash",
  "rohit-choudhari-_E6sXQHsgQc-unsplash",
  "sean-fahrenbruch-KUXkBy_Q0eA-unsplash",
  "sean-fahrenbruch-_07FxAO8oG0-unsplash",
  "sean-fahrenbruch-g95tsUeCohM-unsplash",
  "sean-sinclair-C_NJKfnTR5A-unsplash",
];

const darkImages: string[] = [
  "aedrian-salazar-kVENOffxjZg-unsplash",
  "alexander-x-KtUjim68XEc-unsplash",
  "alexander-x-M4L2tlmqVus-unsplash",
  "allec-gomes-ZGp6H2MQtu4-unsplash",
  "andrey-soldatov-i4Q6JcbFABc-unsplash",
  "antonius-harel-4LY13pRPXSo-unsplash",
  "antonius-harel-HaJoTW4ip-Y-unsplash",
  "antonius-harel-MWzVeAb34P8-unsplash",
  "antonius-harel-n-Tyeypj9hU-unsplash",
  "antonius-harel-r1hj0fblqkY-unsplash",
  "bill-hamway-24Uv4wRJ95A-unsplash",
  "bruno-martins-ElUbmfsgvV0-unsplash",
  "codioful-formerly-gradienta-1Ec-3-OuvPE-unsplash",
  "codioful-formerly-gradienta-1nqc_X3IWMg-unsplash(1)",
  "codioful-formerly-gradienta-1nqc_X3IWMg-unsplash",
  "codioful-formerly-gradienta-7E5kq_sW0Ew-unsplash",
  "codioful-formerly-gradienta-LLhDtJXJvE0-unsplash",
  "codioful-formerly-gradienta-RiUKrRjZud0-unsplash",
  "codioful-formerly-gradienta-YH_-xFrG8fc-unsplash",
  "jan-kopriva-L-bVMhRb5cs-unsplash",
  "kunal-patil-8ZKlgI_G-mw-unsplash",
  "lucrezia-carnelos-Sp6MXlY_2wc-unsplash",
  "mohammed-kara--n9dcIoAIuE-unsplash",
  "mohammed-kara-LpYWTqT4Ff0-unsplash",
  "omid-armin-NeTAp5yme0A-unsplash",
  "omid-armin-di2Kx4FwzFM-unsplash",
  "ruido-98-ZmNVl-nFUaM-unsplash",
  "ryunosuke-kikuno-lwvuKVgT4AU-unsplash",
  "sandip-kalal-5feFTJcPa50-unsplash",
  "valentin-NT9QgSMddNg-unsplash",
];

const lightImage = lightImages[day % lightImages.length]!;
const darkImage  = darkImages[day % darkImages.length]!;

const getUnsplashData = (filename: string) => {
  const clean = filename.replace('-unsplash', '').replace(/\(\d+\)$/, '');
  const lastDash = clean.lastIndexOf('-');
  
  if (lastDash === -1) {
    return {
      url: `https://unsplash.com/photos/${clean}`,
      author: 'Unknown'
    };
  }

  const authorSlug = clean.slice(0, lastDash);
  const authorName = authorSlug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

  return {
    url: `https://unsplash.com/photos/${clean}`,
    author: authorName
  };
};

const lightUnsplash = getUnsplashData(lightImage);
const darkUnsplash = getUnsplashData(darkImage);

const ogImage = new URL(`/backgrounds/light/${lightImage}.jpg`, Astro.site).toString();

/** Nonce provided by middleware for script/style authorization under CSP. */
const cspNonce = typeof Astro.locals.cspNonce === "string" ? Astro.locals.cspNonce : undefined;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects/", label: "Projects" },
  { href: "/about/", label: "About" }
];

const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname.startsWith(href);
};
---

<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <ClientRouter />
    
    <!-- Trusted Types configuration for modern browser security. -->
    <script is:inline nonce={cspNonce}>if(globalThis.trustedTypes&&globalThis.trustedTypes.createPolicy){try{if(!globalThis.trustedTypes.defaultPolicy){globalThis.trustedTypes.createPolicy("default",{createHTML:s=>s,createScript:s=>s,createScriptURL:s=>s})}}catch{}}</script>

    <!-- Theme and quality-of-service (QoS) initialization.
         Executed inline to prevent Flash of Unstyled Content (FOUC). -->
    <script is:inline nonce={cspNonce}>(()=>{try{const t=document.documentElement,e=localStorage.getItem("theme");if(e==="ivory"||e==="midnight"){t.dataset.theme=e}const n=t.dataset.theme==="ivory"||t.dataset.theme==="midnight"?t.dataset.theme:"ivory",a=i=>`bg-scene-quality-20260404hq-${i}`,s=sessionStorage.getItem(a(n));if(s==="tiny"||s==="avif"||s==="webp"||s==="default"){t.dataset.sceneQuality=s}}catch{}})();</script>
    <script>
      import "../scripts/page-transition.ts";
    </script>
    <script>
      import "../scripts/nav-state.ts";
    </script>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content={theme === "midnight" ? "#02060d" : "#ece9e3"} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical ?? pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    {canonical && <link rel="canonical" href={canonical} />}
    <script>
      import "../scripts/theme-toggle.ts";
    </script>
    
    <!-- Dynamic CSS injection for background image variations.
         Variables are used by CSS to swap background quality levels (AVIF/WebP/Tiny)
         reactively based on client-side feature detection and loading state. -->
    <style is:inline nonce={cspNonce} set:html={`
      :root {
        --scene-image-default-light: url("/backgrounds/light/${lightImage}.jpg?v=20260404hq");
        --scene-image-tiny-light: url("/backgrounds/light/${lightImage}.tiny.webp?v=20260404hq");
        --scene-image-webp-light: url("/backgrounds/light/${lightImage}.webp?v=20260404hq");
        --scene-image-avif-light: url("/backgrounds/light/${lightImage}.avif?v=20260404hq");

        --scene-image-default-dark: url("/backgrounds/dark/${darkImage}.jpg?v=20260404hq");
        --scene-image-tiny-dark: url("/backgrounds/dark/${darkImage}.tiny.webp?v=20260404hq");
        --scene-image-webp-dark: url("/backgrounds/dark/${darkImage}.webp?v=20260404hq");
        --scene-image-avif-dark: url("/backgrounds/dark/${darkImage}.avif?v=20260404hq");
      }

      html[data-theme="ivory"], html:not([data-theme]) {
        --scene-image-default: var(--scene-image-default-light);
        --scene-image-tiny: var(--scene-image-tiny-light);
        --scene-image-webp: var(--scene-image-webp-light);
        --scene-image-avif: var(--scene-image-avif-light);
        --scene-image: var(--scene-image-default);
      }
      html[data-theme="midnight"] {
        --scene-image-default: var(--scene-image-default-dark);
        --scene-image-tiny: var(--scene-image-tiny-dark);
        --scene-image-webp: var(--scene-image-webp-dark);
        --scene-image-avif: var(--scene-image-avif-dark);
        --scene-image: var(--scene-image-default);
      }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme]) {
          --scene-image-default: var(--scene-image-default-dark);
          --scene-image-tiny: var(--scene-image-tiny-dark);
          --scene-image-webp: var(--scene-image-webp-dark);
          --scene-image-avif: var(--scene-image-avif-dark);
          --scene-image: var(--scene-image-default);
        }
      }

      html[data-scene-quality="tiny"] { --scene-image: var(--scene-image-tiny, var(--scene-image-default)); }
      html[data-scene-quality="webp"] { --scene-image: var(--scene-image-webp, var(--scene-image-default)); }
      html[data-scene-quality="avif"] { --scene-image: var(--scene-image-avif, var(--scene-image-default)); }
      html[data-scene-quality="default"] { --scene-image: var(--scene-image-default); }
    `}></style>

    <!-- Expose the selected background config to the client-side background-loader.ts -->
    <script is:inline nonce={cspNonce} set:html={`globalThis.__BACKGROUND_CONFIG={ivory:"/backgrounds/light/${lightImage}.jpg",midnight:"/backgrounds/dark/${darkImage}.jpg"};`}></script>
    <script>
      import "../scripts/background-loader.ts";
    </script>
  </head>
  <body>
    <div id="scene-bg" aria-hidden="true" transition:persist="scene-bg"></div>
    <div class="ambient-orb ambient-orb-one" aria-hidden="true" transition:persist="ambient-orb-one"></div>
    <div class="ambient-orb ambient-orb-two" aria-hidden="true" transition:persist="ambient-orb-two"></div>
    <main class:list={{ "page-shell": true, "page-shell-plain": !shell }}>
      {
        shell ? (
          <section class="app-shell">
            <header class="app-topbar" transition:persist={topbarPersistKey}>
              <div class="app-controls">
                <nav class="app-nav" aria-label="Primary">
                  {navItems.map((item) => (
                    <a
                      class:list={{ "app-tab": true, "is-active": isActive(item.href) }}
                      data-nav-link
                      data-nav-href={item.href}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  ))}
                </nav>
                <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
                  <span class="theme-toggle-label theme-toggle-label-ivory">Ivory</span>
                  <span class="theme-toggle-label theme-toggle-label-midnight">Midnight</span>
                  <span class="theme-toggle-thumb" aria-hidden="true"></span>
                </button>
              </div>
            </header>

            <section class="app-content">
              <slot />
            </section>
          </section>
        ) : (
          <>
            <header class="app-topbar app-topbar-plain" transition:persist={topbarPersistKey}>
              <div class="app-controls">
                <nav class="app-nav" aria-label="Primary">
                  {navItems.map((item) => (
                    <a
                      class:list={{ "app-tab": true, "is-active": isActive(item.href) }}
                      data-nav-link
                      data-nav-href={item.href}
                      href={item.href}
                      aria-current={isActive(item.href) ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  ))}
                </nav>
                <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
                  <span class="theme-toggle-label theme-toggle-label-ivory">Ivory</span>
                  <span class="theme-toggle-label theme-toggle-label-midnight">Midnight</span>
                  <span class="theme-toggle-thumb" aria-hidden="true"></span>
                </button>
              </div>
            </header>

            <section class="app-content app-content-plain">
              <slot />
            </section>
          </>
        )
      }
    </main>

    <a href={lightUnsplash.url} class="bg-credit bg-credit-light" target="_blank" rel="noopener noreferrer">Background by {lightUnsplash.author}</a>
    <a href={darkUnsplash.url} class="bg-credit bg-credit-dark" target="_blank" rel="noopener noreferrer">Background by {darkUnsplash.author}</a>

    <style>
      .bg-credit {
        position: fixed;
        bottom: 1.25rem;
        left: 1.25rem;
        display: inline-flex;
        align-items: center;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-muted);
        text-decoration: none;
        z-index: 50;
        opacity: 0.65;
        transition: opacity var(--motion-medium) ease, color var(--motion-medium) ease, background-color var(--motion-medium) ease, border-color var(--motion-medium) ease;
        padding: 0.45rem 0.85rem;
        background: var(--glass-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid var(--border-color);
        border-radius: 8px;
      }
      .bg-credit:hover {
        opacity: 1;
        color: var(--text-main);
        background: var(--button-bg-hover);
        border-color: var(--button-border-strong);
      }
      html[data-theme="ivory"] .bg-credit-dark,
      html:not([data-theme]) .bg-credit-dark {
        display: none;
      }
      html[data-theme="midnight"] .bg-credit-light {
        display: none;
      }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme]) .bg-credit-light {
          display: none;
        }
        html:not([data-theme]) .bg-credit-dark {
          display: inline-flex;
        }
      }
    </style>
  </body>
</html>
